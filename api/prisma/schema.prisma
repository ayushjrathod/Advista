// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageRole {
  USER
  MODEL
}

enum ResearchRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model Session {
  id         String   @id @default(uuid())
  user_id    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  brief         ResearchBrief?
  messages      Message[]
  research_runs ResearchRun[]

  @@index([user_id])
}

model Message {
  id         String      @id @default(uuid())
  session_id String
  session    Session     @relation(fields: [session_id], references: [id], onDelete: Cascade)
  role       MessageRole
  content    String
  created_at DateTime    @default(now())

  @@index([session_id, created_at])
}

// Mirrors models/research_brief.py.
model ResearchBrief {
  id         String  @id @default(uuid())
  session_id String  @unique
  session    Session @relation(fields: [session_id], references: [id], onDelete: Cascade)

  company_name           String   @default("")
  product_description    String   @default("")
  target_customers       String   @default("")
  competitor_names       String[]
  strategic_goals        String   @default("")
  primary_channels       String[]
  positioning_hypothesis String   @default("")
  additional_context     String   @default("")

  updated_at DateTime @updatedAt
}

model ResearchRun {
  id         String            @id @default(uuid())
  session_id String
  session    Session           @relation(fields: [session_id], references: [id], onDelete: Cascade)
  status     ResearchRunStatus @default(PENDING)

  brief_snapshot Json
  search_params  Json?
  error          String?

  report Report?

  created_at   DateTime  @default(now())
  started_at   DateTime?
  completed_at DateTime?

  @@index([session_id, created_at])
}

//  Mirrors CompetitiveIntelligenceReport
// in models/research_report.py.
model Report {
  id     String      @id @default(uuid())
  run_id String      @unique
  run    ResearchRun @relation(fields: [run_id], references: [id], onDelete: Cascade)

  executive_summary     String   @default("")
  product_positioning   String   @default("")
  competitive_landscape String   @default("")
  customer_sentiment    String   @default("")
  strategic_gaps        String[]
  pricing_intelligence  String   @default("")
  corporate_momentum    String   @default("")
  integration_ecosystem String   @default("")
  recommended_actions   String[]
  sources               String[]

  created_at DateTime @default(now())
}
